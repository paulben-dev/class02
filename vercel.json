{
  "installCommand": "npm install && cd teacher && npm install",
  "buildCommand": "cd teacher && npm run build && rm -f index.html",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/teacher/assets/(.*)", "destination": "/teacher/dist/assets/$1" },
    { "source": "/teacher/(.*)", "destination": "/teacher/dist/index.html" }
  ]
}
